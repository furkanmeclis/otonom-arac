# ============================================================
# Makineye özel ayarlar — ŞABLON
# Bu dosyayı ".env" olarak KOPYALA ve kendi değerlerinle doldur.
#   cp .env.example .env   (veya Windows: copy .env.example .env)
# .env git'e GİRMEZ; herkes kendi .env'ini tutar.
# ============================================================

# DonkeyCar simülatör binary yolu (SADECE simülasyon için gerekli)
#   Windows: C:/path/DonkeySimWin/donkey_sim.exe
#   Linux:   /path/DonkeySimLinux/donkey_sim.x86_64
#   Mac:     /path/donkey_sim.app/Contents/MacOS/donkey_sim
#   Simülatörü elle başlatacaksan / gerçek araçta: remote
DONKEY_SIM_PATH=remote

# Gerçek araç (Jetson/Raspberry Pi) SSH bilgileri (opsiyonel)
PI_USERNAME=pi
PI_HOSTNAME=donkeypi.local
